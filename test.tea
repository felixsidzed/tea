using "io";
using "str";
using "mem";

class String {
	public raw: string;

	constructor(string _raw)
		raw = _raw;
	end

	deconstructor()
		mem::free(raw);
	end

	public func at(int idx) -> char
		return raw[idx];
	end
}

public func main()
	var str = new String("Hello, World!");
	io::printf("%c\n", str.at(1));

	return 0;
end
