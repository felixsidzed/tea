using "io";

class Test {
	public value: int;

	constructor(int v)
		value = v;
	end
}

public func doStuff(Test* object)
	object->value = 5;
end

public func main()
	var object = new Test(3);
	io::printf("object.value = %d\n", object.value);
	doStuff(&object);
	io::printf("object.value = %d\n", object.value);

	return 0;
end
