using "io";

class Test {
	public value: int;
	private factor: int;

	constructor(int v)
		value = v;
		factor = 5;
	end

	public func compute() -> int
		return value * factor;
	end
}

public func doStuff(Test object)
	io::printf("Test.compute() = %d\n", object.compute());
end

public func main()
	var object = new Test(3);
	io::printf("object.value = %d\n", object.value);
	doStuff(object);

	var object2 = object;
	object2.value = 11;
	io::printf("object.value = %d\n", object.value);
	io::printf("object2.value = %d\n", object2.value);
	doStuff(object2);

	return 0;
end
