using "io";

class Test {
	public value: int;
	private factor: int;

	constructor(int v)
		value = v;
		factor = 5;
	end

	public func compute() -> int
		return value * factor;
	end
}

public func doStuff(Test object)
	io::printf("Test.compute() = %d\n", object.compute());
end

public func main()
	var object = new Test(3);
	doStuff(object);

	return 0;
end
