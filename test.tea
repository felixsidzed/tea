using "io";
using "core";

public func test() -> void
	core::throw("ts real bad error brochacho");
end

public func main()
	var error = core::pcall(test);	// pcall returns a 'null' if the function did not throw
									// otherwise the error message
	if (!error) do
		io::printf("error: %s\n", error);
	else
		io::printf("w*rks\n");
	end

	return 0;
end
